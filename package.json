{
  "name": "tagdragon",
  "type": "module",
  "version": "1.6.1",
  "description": "Chrome DevTools extension that captures and decodes network requests from marketing/analytics tracking services",
  "main": "dist/panel.js",
  "scripts": {
    "dev": "concurrently \"npm:watch:css\" \"npm:watch:js\"",
    "watch:css": "tailwindcss -i styles/input.css -o dist/panel.css --watch",
    "watch:js": "rollup -c -w",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i styles/input.css -o dist/panel.css --minify",
    "build:js": "rollup -c --environment NODE_ENV:production",
    "clean": "rm -rf dist/*",
    "generate-icons": "node scripts/generate-icons.mjs",
    "analyze": "ANALYZE=true npm run build:js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepare": "husky"
  },
  "keywords": [
    "chrome-extension",
    "devtools",
    "analytics",
    "tracking",
    "ga4",
    "google-analytics",
    "adobe-analytics",
    "meta-pixel"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "eslint",
      "prettier --write"
    ]
  },
  "author": "Ondřej Bezucha",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chrome": "^0.1.39",
    "concurrently": "^8.2.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide": "^1.7.0",
    "prettier": "^3.8.1",
    "rollup": "^4.9.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
